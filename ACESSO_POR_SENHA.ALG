Algoritmo "acesso_por_senha"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 02/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
n_tentativas, max_tentativas : inteiro
senha, senha_input: caractere

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
senha <- "1234"
senha_input <- ""
n_tentativas <- 0
max_tentativas <- 3

escreval("Bem-vindo")
enquanto n_tentativas < max_tentativas faca
   escreval("Por favor, digite a senha ")
   leia(senha_input)

   se senha_input = senha entao
      escreval("Acesso permitido")
      interrompa
   senao
      n_tentativas <- n_tentativas + 1
      se n_tentativas < max_tentativas entao
      escreval("Senha incorreta, vocę possui mais ", max_tentativas - n_tentativas)
      senao
      escreval("Acesso bloqueado")
      fimse
   fimse
   
fimenquanto

Fimalgoritmo